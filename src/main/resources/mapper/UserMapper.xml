<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.txy.chefdemo.mapper.UserMapper">

    <!-- ===================== resultMap ===================== -->
    <resultMap id="UserResultMap" type="com.txy.chefdemo.domain.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="role" property="role"/>
        <result column="avatar" property="avatar"/>
        <result column="phone" property="phone"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- ===================== upsert ===================== -->
    <insert id="upsert">
        INSERT INTO user
        (
            username, password, role,
            avatar, phone, status,
            last_login_time, create_time, update_time
        )
        VALUES
            (
                #{user.username}, #{user.password}, #{user.role},
                #{user.avatar}, #{user.phone}, #{user.status},
                #{user.lastLoginTime}, #{user.createTime}, #{user.updateTime}
            )
            ON DUPLICATE KEY UPDATE
                                 password        = VALUES(password),
                                 role            = VALUES(role),
                                 avatar          = VALUES(avatar),
                                 phone           = VALUES(phone),
                                 status          = VALUES(status),
                                 last_login_time = VALUES(last_login_time),
                                 update_time     = VALUES(update_time)
    </insert>

    <!-- ===================== 基础查询 ===================== -->
    <select id="queryById" resultMap="UserResultMap">
        SELECT * FROM user
        WHERE id = #{id}
    </select>

    <select id="queryByUsername" resultMap="UserResultMap">
        SELECT * FROM user
        WHERE username = #{username}
    </select>

    <!-- ===================== 条件查询 ===================== -->
    <select id="queryUserListByCondition" resultMap="UserResultMap">
        SELECT * FROM user
        <where>

            <if test="search != null">

                <if test="search.userId != null and search.userId > 0">
                    AND id = #{search.userId}
                </if>

                <if test="search.userName != null and search.userName != ''">
                    AND username LIKE CONCAT('%', #{search.userName}, '%')
                </if>

                <if test="search.role != null and search.role > 0">
                    AND role = #{search.role}
                </if>

                <if test="search.status != null and search.status > 0">
                    AND status = #{search.status}
                </if>

                <if test="search.startTime != null and search.startTime > 0">
                    AND create_time &gt;= #{search.startTime}
                </if>

                <if test="search.endTime != null and search.endTime > 0">
                    AND create_time &lt;= #{search.endTime}
                </if>
            </if>

        </where>
        ORDER BY create_time DESC
        <if test="search != null and search.offset != null and search.size != null and search.size > 0">
            LIMIT #{search.offset}, #{search.size}
        </if>
    </select>
    <select id="queryUserListCnt" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM user
        <where>
            <if test="search != null">

                <if test="search.userId != null and search.userId > 0">
                    AND id = #{search.userId}
                </if>

                <if test="search.userName != null and search.userName != ''">
                    AND username LIKE CONCAT('%', #{search.userName}, '%')
                </if>

                <if test="search.role != null and search.role > 0">
                    AND role = #{search.role}
                </if>

                <if test="search.status != null and search.status > 0">
                    AND status = #{search.status}
                </if>

                <if test="search.startTime != null and search.startTime > 0">
                    AND create_time &gt;= #{search.startTime}
                </if>

                <if test="search.endTime != null and search.endTime > 0">
                    AND create_time &lt;= #{search.endTime}
                </if>
            </if>

        </where>
    </select>
    <select id="queryByIdList" resultMap="UserResultMap">
        SELECT * FROM user
        <where>
        <if test="chefIdList != null and chefIdList.size() > 0">
            AND id IN
            <foreach collection="chefIdList" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>
        </if>
        </where>
    </select>

</mapper>
