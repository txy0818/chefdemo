<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.txy.chefdemo.mapper.WalletMapper">

    <resultMap id="WalletResultMap" type="com.txy.chefdemo.domain.Wallet">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="balance" property="balance"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="upsert" parameterType="com.txy.chefdemo.domain.Wallet">
        INSERT INTO wallet
            (user_id, balance, create_time, update_time)
        VALUES
            (#{wallet.userId}, #{wallet.balance}, #{wallet.createTime}, #{wallet.updateTime})
            ON DUPLICATE KEY UPDATE
                                 balance = #{wallet.balance},
                                 update_time = #{wallet.updateTime}
    </insert>

    <select id="queryById" resultMap="WalletResultMap">
        SELECT * FROM wallet WHERE id = #{id}
    </select>

    <select id="queryByUserId" resultMap="WalletResultMap">
        SELECT * FROM wallet WHERE user_id = #{userId}
    </select>
</mapper>
