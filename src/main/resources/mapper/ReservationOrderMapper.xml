<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.txy.chefdemo.mapper.ReservationOrderMapper">

    <!-- ========================= -->
    <!-- 1. ResultMap -->
    <!-- ========================= -->
    <resultMap id="ReservationOrderResultMap" type="com.txy.chefdemo.domain.ReservationOrder">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="chef_id" property="chefId"/>
        <result column="chef_available_time_id" property="chefAvailableTimeId"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="total_time" property="totalTime"/>
        <result column="total_amount" property="totalAmount"/>
        <result column="people_count" property="peopleCount"/>
        <result column="special_requirements" property="specialRequirements"/>
        <result column="contact_name" property="contactName"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="contact_address" property="contactAddress"/>
        <result column="status" property="status"/>
        <result column="pay_status" property="payStatus"/>
        <result column="cancel_reason" property="cancelReason"/>
        <result column="pay_deadline_time" property="payDeadlineTime"/>
        <result column="pay_time" property="payTime"/>
        <result column="accept_time" property="acceptTime"/>
        <result column="complete_time" property="completeTime"/>
        <result column="cancel_time" property="cancelTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- ========================= -->
    <!-- 2. 公共字段 -->
    <!-- ========================= -->
    <sql id="Base_Column_List">
        id, user_id, chef_id, chef_available_time_id,
        start_time, end_time, total_time, total_amount,
        people_count, special_requirements,
        contact_name, contact_phone, contact_address,
        status, pay_status, cancel_reason,
        pay_deadline_time, pay_time, accept_time,
        complete_time, cancel_time,
        create_time, update_time
    </sql>

    <!-- ========================= -->
    <!-- 3. 插入 -->
    <!-- ========================= -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="order.id">
        INSERT INTO reservation_order
        (user_id, chef_id, chef_available_time_id,
         start_time, end_time, total_time, total_amount,
         people_count, special_requirements,
         contact_name, contact_phone, contact_address,
         status, pay_status, cancel_reason,
         pay_deadline_time, pay_time, accept_time,
         complete_time, cancel_time,
         create_time, update_time)
        VALUES
            (#{order.userId}, #{order.chefId}, #{order.chefAvailableTimeId},
             #{order.startTime}, #{order.endTime}, #{order.totalTime}, #{order.totalAmount},
             #{order.peopleCount}, #{order.specialRequirements},
             #{order.contactName}, #{order.contactPhone}, #{order.contactAddress},
             #{order.status}, #{order.payStatus}, #{order.cancelReason},
             #{order.payDeadlineTime}, #{order.payTime}, #{order.acceptTime},
             #{order.completeTime}, #{order.cancelTime},
             #{order.createTime}, #{order.updateTime})
    </insert>

    <update id="updateById">
        UPDATE reservation_order
        <set>
            <if test="order.userId != null and order.userId > 0">
                user_id = #{order.userId},
            </if>

            <if test="order.chefId != null and order.chefId > 0">
                chef_id = #{order.chefId},
            </if>

            <if test="order.chefAvailableTimeId != null and order.chefAvailableTimeId > 0">
                chef_available_time_id = #{order.chefAvailableTimeId},
            </if>

            <if test="order.startTime != null and order.startTime > 0">
                start_time = #{order.startTime},
            </if>

            <if test="order.endTime != null and order.endTime > 0">
                end_time = #{order.endTime},
            </if>

            <if test="order.totalTime != null and order.totalTime > 0">
                total_time = #{order.totalTime},
            </if>

            <if test="order.totalAmount != null and order.totalAmount > 0">
                total_amount = #{order.totalAmount},
            </if>

            <if test="order.peopleCount != null and order.peopleCount > 0">
                people_count = #{order.peopleCount},
            </if>

            <if test="order.specialRequirements != null and order.specialRequirements != ''">
                special_requirements = #{order.specialRequirements},
            </if>

            <if test="order.contactName != null and order.contactName != ''">
                contact_name = #{order.contactName},
            </if>

            <if test="order.contactPhone != null and order.contactPhone != ''">
                contact_phone = #{order.contactPhone},
            </if>

            <if test="order.contactAddress != null and order.contactAddress != ''">
                contact_address = #{order.contactAddress},
            </if>

            <if test="order.status != null and order.status > 0">
                status = #{order.status},
            </if>

            <if test="order.payStatus != null and order.payStatus > 0">
                pay_status = #{order.payStatus},
            </if>

            <if test="order.cancelReason != null and order.cancelReason != ''">
                cancel_reason = #{order.cancelReason},
            </if>

            <if test="order.payDeadlineTime != null and order.payDeadlineTime > 0">
                pay_deadline_time = #{order.payDeadlineTime},
            </if>

            <if test="order.payTime != null and order.payTime > 0">
                pay_time = #{order.payTime},
            </if>

            <if test="order.acceptTime != null and order.acceptTime > 0">
                accept_time = #{order.acceptTime},
            </if>

            <if test="order.completeTime != null and order.completeTime > 0">
                complete_time = #{order.completeTime},
            </if>

            <if test="order.cancelTime != null and order.cancelTime > 0">
                cancel_time = #{order.cancelTime},
            </if>

            update_time = #{order.updateTime}

        </set>

        WHERE id = #{order.id}
    </update>

    <!-- ========================= -->
    <!-- 4. 动态查询条件 -->
    <!-- ========================= -->
    <sql id="Base_Where_Clause">
        <where>

            <if test="searchBo.orderId != null">
                AND id = #{searchBo.orderId}
            </if>

            <if test="searchBo.orderIds != null and searchBo.orderIds.size() > 0">
                AND id IN
                <foreach collection="searchBo.orderIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>

            <if test="searchBo.userId != null">
                AND user_id = #{searchBo.userId}
            </if>

            <if test="searchBo.userIds != null and searchBo.userIds.size() > 0">
                AND user_id IN
                <foreach collection="searchBo.userIds" item="uid" open="(" separator="," close=")">
                    #{uid}
                </foreach>
            </if>

            <if test="searchBo.chefId != null">
                AND chef_id = #{searchBo.chefId}
            </if>

            <if test="searchBo.chefIds != null and searchBo.chefIds.size() > 0">
                AND chef_id IN
                <foreach collection="searchBo.chefIds" item="cid" open="(" separator="," close=")">
                    #{cid}
                </foreach>
            </if>

            <if test="searchBo.status != null">
                AND status = #{searchBo.status}
            </if>

            <if test="searchBo.statuses != null and searchBo.statuses.size() > 0">
                AND status IN
                <foreach collection="searchBo.statuses" item="st" open="(" separator="," close=")">
                    #{st}
                </foreach>
            </if>

            <if test="searchBo.startTime != null and searchBo.startTime > 0">
                AND create_time &gt;= #{searchBo.startTime}
            </if>
            <if test="searchBo.endTime != null and searchBo.endTime > 0">
                AND create_time &lt;= #{searchBo.endTime}
            </if>
            <if test="searchBo.chefAvailableTimeId != null and searchBo.chefAvailableTimeId > 0">
                AND chef_available_time_id = #{searchBo.chefAvailableTimeId}
            </if>
        </where>
    </sql>

    <!-- ========================= -->
    <!-- 5. 条件查询（分页） -->
    <!-- ========================= -->
    <select id="queryByCondition"
            resultMap="ReservationOrderResultMap">

        SELECT
        <include refid="Base_Column_List"/>
        FROM reservation_order

        <include refid="Base_Where_Clause"/>

        ORDER BY create_time DESC

        <if test="searchBo.offset != null and searchBo.size != null">
            LIMIT #{searchBo.offset}, #{searchBo.size}
        </if>

    </select>

    <!-- ========================= -->
    <!-- 6. 查询数量 -->
    <!-- ========================= -->
    <select id="queryCnt"
            resultType="java.lang.Integer">

        SELECT COUNT(*)
        FROM reservation_order

        <include refid="Base_Where_Clause"/>

    </select>

</mapper>
