<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.txy.chefdemo.mapper.ReportMapper">

    <!-- ===================== resultMap ===================== -->
    <resultMap id="ReportResultMap" type="com.txy.chefdemo.domain.Report">
        <id column="id" property="id"/>
        <result column="reservation_order_id" property="reservationOrderId"/>
        <result column="reporter_id" property="reporterId"/>
        <result column="target_user_id" property="targetUserId"/>
        <result column="reason" property="reason"/>
        <result column="process_result" property="processResult"/>
        <result column="processed_by" property="processedBy"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="report.id">
        INSERT INTO report
        (
            reservation_order_id, reporter_id, target_user_id,
            reason, process_result,
            processed_by, status, create_time, update_time
        )
        VALUES
            (
                #{report.reservationOrderId}, #{report.reporterId}, #{report.targetUserId},
                #{report.reason}, #{report.processResult},
                #{report.processedBy},
                #{report.status}, #{report.createTime}, #{report.updateTime}
            )
    </insert>

    <update id="updateById">
        UPDATE report
        SET
            reservation_order_id = #{report.reservationOrderId},
            reporter_id = #{report.reporterId},
            target_user_id = #{report.targetUserId},
            reason = #{report.reason},
            process_result = #{report.processResult},
            processed_by = #{report.processedBy},
            status = #{report.status},
            update_time = #{report.updateTime}
        WHERE id = #{report.id}
    </update>

    <!-- ===================== 条件查询 ===================== -->
    <select id="queryByCondition" resultMap="ReportResultMap">
        SELECT * FROM report
        <where>

            <!-- 单个ID -->
            <if test="searchBo.reportId != null and searchBo.reportId > 0">
                AND id = #{searchBo.reportId}
            </if>

            <!-- 批量ID -->
            <if test="searchBo.reportIds != null and searchBo.reportIds.size() > 0">
                AND id IN
                <foreach collection="searchBo.reportIds" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>

            <!-- 订单 -->
            <if test="searchBo.orderId != null and searchBo.orderId > 0">
                AND reservation_order_id = #{searchBo.orderId}
            </if>

            <if test="searchBo.orderIds != null and searchBo.orderIds.size() > 0">
                AND reservation_order_id IN
                <foreach collection="searchBo.orderIds" item="oid" open="(" close=")" separator=",">
                    #{oid}
                </foreach>
            </if>

            <!-- 举报人 -->
            <if test="searchBo.userId != null and searchBo.userId > 0">
                AND reporter_id = #{searchBo.userId}
            </if>

            <if test="searchBo.userIds != null and searchBo.userIds.size() > 0">
                AND reporter_id IN
                <foreach collection="searchBo.userIds" item="uid" open="(" close=")" separator=",">
                    #{uid}
                </foreach>
            </if>

            <!-- 被举报人 -->
            <if test="searchBo.targetUserId != null and searchBo.targetUserId > 0">
                AND target_user_id = #{searchBo.targetUserId}
            </if>

            <if test="searchBo.targetUserIds != null and searchBo.targetUserIds.size() > 0">
                AND target_user_id IN
                <foreach collection="searchBo.targetUserIds" item="tid" open="(" close=")" separator=",">
                    #{tid}
                </foreach>
            </if>

            <!-- 状态 -->
            <if test="searchBo.status != null and searchBo.status > 0">
                AND status = #{searchBo.status}
            </if>

            <if test="searchBo.statuses != null and searchBo.statuses.size() > 0">
                AND status IN
                <foreach collection="searchBo.statuses" item="st" open="(" close=")" separator=",">
                    #{st}
                </foreach>
            </if>

        </where>

        ORDER BY create_time DESC

        <if test="searchBo.offset != null and searchBo.size > 0">
            LIMIT #{searchBo.offset}, #{searchBo.size}
        </if>
    </select>

    <!-- ===================== 统计数量 ===================== -->
    <select id="queryCnt" resultType="int">
        SELECT COUNT(1)
        FROM report
        <where>

            <if test="searchBo.reportId != null and searchBo.reportId > 0">
                AND id = #{searchBo.reportId}
            </if>

            <if test="searchBo.reportIds != null and searchBo.reportIds.size() > 0">
                AND id IN
                <foreach collection="searchBo.reportIds" item="id" open="(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>

            <if test="searchBo.orderId != null and searchBo.orderId > 0">
                AND reservation_order_id = #{searchBo.orderId}
            </if>

            <if test="searchBo.orderIds != null and searchBo.orderIds.size() > 0">
                AND reservation_order_id IN
                <foreach collection="searchBo.orderIds" item="oid" open="(" close=")" separator=",">
                    #{oid}
                </foreach>
            </if>

            <if test="searchBo.userId != null and searchBo.userId > 0">
                AND reporter_id = #{searchBo.userId}
            </if>

            <if test="searchBo.userIds != null and searchBo.userIds.size() > 0">
                AND reporter_id IN
                <foreach collection="searchBo.userIds" item="uid" open="(" close=")" separator=",">
                    #{uid}
                </foreach>
            </if>

            <if test="searchBo.targetUserId != null and searchBo.targetUserId > 0">
                AND target_user_id = #{searchBo.targetUserId}
            </if>

            <if test="searchBo.targetUserIds != null and searchBo.targetUserIds.size() > 0">
                AND target_user_id IN
                <foreach collection="searchBo.targetUserIds" item="tid" open="(" close=")" separator=",">
                    #{tid}
                </foreach>
            </if>

            <if test="searchBo.status != null and searchBo.status > 0">
                AND status = #{searchBo.status}
            </if>

            <if test="searchBo.statuses != null and searchBo.statuses.size() > 0">
                AND status IN
                <foreach collection="searchBo.statuses" item="st" open="(" close=")" separator=",">
                    #{st}
                </foreach>
            </if>

        </where>
    </select>

</mapper>