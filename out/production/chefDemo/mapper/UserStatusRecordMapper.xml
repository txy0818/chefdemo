<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.txy.chefdemo.mapper.UserStatusRecordMapper">

    <resultMap id="UserStatusRecordResultMap" type="com.txy.chefdemo.domain.UserStatusRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="before_status" property="beforeStatus"/>
        <result column="after_status" property="afterStatus"/>
        <result column="reason" property="reason"/>
        <result column="operator_id" property="operatorId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="record.id">
        INSERT INTO user_status_record
        (user_id, before_status, after_status, reason, operator_id, create_time)
        VALUES
        (#{record.userId}, #{record.beforeStatus}, #{record.afterStatus}, #{record.reason},
         #{record.operatorId}, #{record.createTime})
    </insert>

    <select id="queryByUserId" resultMap="UserStatusRecordResultMap">
        SELECT * FROM user_status_record WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>
</mapper>
